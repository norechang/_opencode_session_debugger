{
  "name": "opencode-session-debugger",
  "version": "1.0.0",
  "description": "OpenCode plugin for tracking and debugging session execution, prompt parsing, agent invocations, and tool usage",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opencode-debug": "./dist/cli/analyze.js"
  },
  "scripts": {
    "build": "tsc && node scripts/postbuild.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "debugging",
    "logging",
    "session",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
